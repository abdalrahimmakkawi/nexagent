# ============================================================
# NEXAGENT — Environment Variables
# Copy this file to .env.local and fill in your keys
# NEVER commit .env.local to git
# ============================================================

# --- NVIDIA API ---
# Get your key at: https://build.nvidia.com/
NVIDIA_API_KEY=your-nvidia-api-key-here

# --- Anthropic (Claude) ---
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Google AI (Gemini) ---
# Get your key at: https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=your-gemini-key-here

# --- Agent Routing ---
# "nvidia"  → always use NVIDIA
# "claude"  → always use Claude
# "gemini"  → always use Gemini
# "auto"    → Claude for complex/sensitive, Gemini for fast/simple
AI_ROUTING_MODE=nvidia

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=NexAgent

# --- Optional: Analytics ---
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
